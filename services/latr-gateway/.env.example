# L@tr gateway environment variables
# Copy to `.env` for local runs: export $(grep -v '^#' .env | xargs) && swift run LatrGateway

# --- Server ---
PORT=8080
APP_ENV=local
PLC_URL=https://plc.directory

# --- Federated public reads (subject metadata + Bluesky URL normalization) ---
# AppView bases used after DID-document discovery (repo DID #bsky_appview / #atproto_appview).
# LATR_GATEWAY_APPVIEW_URLS=https://public.api.bsky.app,https://your.appview.example
# Identity relay for handle → DID (com.atproto.identity.resolveHandle).
# LATR_GATEWAY_IDENTITY_URL=https://bsky.social
#
# Open Graph enhancement runs direct HTML first, then queries Microlink, Jina Reader,
# and Cardyb (https://cardyb.bsky.app) in parallel and keeps the strongest preview.

# --- OAuth client allowlist (user access tokens) ---
# OAUTH_GATEWAY_REQUIRE_KNOWN_CLIENT=false
# When true (default in prod), gateway routes require a registered X-Latr-Client-Id +
# X-Latr-API-Key pair from the developer store (DATABASE_URL). Legacy official credentials
# via X-Latr-Official-Client remain supported during migration.
# OAUTH_GATEWAY_ALLOWED_CLIENT_IDS is deprecated and ignored.
# (latrkit.dev app: https://github.com/Stygian-Tech/latrkit-dev)

# SPA origin for redirect_uris when serving /oauth/client-metadata.json from the gateway.
# OAUTH_PUBLIC_ORIGIN=https://testing.latr.link

# LatrKit developer console (testing.latrkit.dev) when deployment-protected on Vercel.
# OAUTH_LATRKIT_PUBLIC_ORIGIN=https://testing.latrkit.dev

# --- Application credentials ---
# LATR_GATEWAY_REQUIRE_CLIENT_API_KEY=false

# Internal legacy first-party base64 map (migration only — register clients via latrkit.dev)
# LATR_GATEWAY_OFFICIAL_CLIENT_CREDENTIALS=latr-link-web=REPLACE_ME

# Supabase Postgres — apply migrations/001_developer_console.sql, then set DATABASE_URL (required on Fly).
# DATABASE_URL=postgresql://...

# JSON fallback when DATABASE_URL is unset (local dev only)
# LATR_GATEWAY_DEVELOPER_STORE_PATH=./data/developer-store.json

# Legacy client registry (deprecated; superseded by developer store)
# LATR_GATEWAY_CLIENT_REGISTRY_PATH=./data/client-registry.json
# LATR_GATEWAY_CLIENT_REGISTRATION_SECRET=replace-me
