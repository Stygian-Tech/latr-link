# Copy to `.env.local`. Required for local sign-in (loopback OAuth).

# =============================================================================
# NEXT_PUBLIC_APP_ENV
# =============================================================================
# Drives UX that must differ between localhost and the public site:
# apps/web/src/components/shared/EnvironmentBanner.tsx (ribbon),
# SaveUrlBar verbose / [DEBUG] success copy, library “External / AT record” dev chips
# (apps/web/src/lib/environmentBanner.ts + SavedRows).
#
# IMPORTANT — default when unset (see getAppEnv() in environmentBanner.ts):
#   `next dev` → **local** (blue LOCAL banner)
#   Vercel production build → **prod** (no banner) when VERCEL_ENV=production
#   Vercel preview / other hosted builds → **dev** (amber DEV banner)
#   Explicit NEXT_PUBLIC_APP_ENV or APP_ENV always wins.
#
# Supported values:
#   prod — Public product behavior: no ribbon, generic save messages, no storage
#           dev badges on library rows (see `NEXT_PUBLIC_APP_ENV === "prod"` checks).
#   local — Explicit local workflow: blue LOCAL banner, verbose/debug save copy,
#           dev badges on rows (same as omitting the variable locally).
#   dev — Amber DEV banner plus the same verbose/dev affordances as `local`.
#
# Any other explicit string has no entry in ENVIRONMENT_BANNER_CONFIG — the ribbon
# stays hidden (`EnvironmentBanner.tsx`). SaveUrlBar verbose/debug hints still use
# `showSaveOutcomeDebugLabels()` (`prod` off; `local`/`dev`/loopback on).
#
# Preview deployments: omit both vars for DEV banner, or set prod to mimic production UX.
# APP_ENV=dev
NEXT_PUBLIC_APP_ENV=local

# Same as NEXT_PUBLIC_APP_ENV=local if you prefer:
# NEXT_PUBLIC_ATPROTO_LOCAL=true

# Optional: full redirect URI registered in the loopback client_id (default = this origin + /callback, localhost→127.0.0.1)
# NEXT_PUBLIC_LOCAL_REDIRECT_URI=http://127.0.0.1:3000/callback

# Optional: ms — cap BrowserOAuthClient.load (metadata fetch / init) default 10000
# NEXT_PUBLIC_OAUTH_CLIENT_LOAD_TIMEOUT_MS=10000

# Optional: ms — cap OAuth session restore (default 8000).
# NEXT_PUBLIC_AUTH_RESTORE_TIMEOUT_MS=8000

# Optional: ms — per-request fetch deadline for OAuth HTTP (default 90000). Native fetch has no timeout.
# NEXT_PUBLIC_OAUTH_FETCH_DEADLINE_MS=90000

# Optional: ms — full initCallback budget (default 60000)
# NEXT_PUBLIC_OAUTH_CALLBACK_TIMEOUT_MS=60000

# Optional: use response_mode=query (?code&state on /callback) instead of URL fragment — try if callback never completes.
# NEXT_PUBLIC_OAUTH_RESPONSE_MODE=query

# L@tr gateway (server-side save/list/state).
# Optional override — when unset, defaults by app env:
#   local → http://127.0.0.1:8080
#   dev   → https://api.testing.latr.link on testing.latr.link, otherwise https://latr-link-dev-gateway.fly.dev
#   prod  → https://latr-link-prod-gateway.fly.dev
# NEXT_PUBLIC_LATR_GATEWAY_URL=https://latr-link-dev-gateway.fly.dev

# When the hosted gateway enforces official client credentials, set the latr-web base64 credential
# (must match gateway LATR_GATEWAY_OFFICIAL_CLIENT_CREDENTIALS for latr-web). Ships in the bundle.
# Generate: openssl rand -base64 32
# NEXT_PUBLIC_LATR_GATEWAY_CLIENT_CREDENTIAL=replace-me

# --- Production / hosted metadata (NEXT_PUBLIC_APP_ENV=prod recommended) ---
# Optional override for hosted OAuth (preview/prod). Default: same-origin /client-metadata.json
# NEXT_PUBLIC_ATPROTO_CLIENT_ID=https://latr.link/client-metadata.json
