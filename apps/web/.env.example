# Copy to `.env.local`. Required for local sign-in (loopback OAuth).

# --- Local ATProto OAuth (required) ---
# Enables loopback client_id with /callback + repo scopes (not bare http://localhost).
NEXT_PUBLIC_APP_ENV=local

# Same as NEXT_PUBLIC_APP_ENV=local if you prefer:
# NEXT_PUBLIC_ATPROTO_LOCAL=true

# Optional: full redirect URI registered in the loopback client_id (default = this origin + /callback, localhost→127.0.0.1)
# NEXT_PUBLIC_LOCAL_REDIRECT_URI=http://127.0.0.1:3000/callback

# Optional: ms — cap OAuth session restore so the UI cannot spin forever (default 12000). Embedded browsers may hang on IndexedDB.
# NEXT_PUBLIC_AUTH_RESTORE_TIMEOUT_MS=12000

# --- Production / hosted metadata (when not using local mode) ---
# NEXT_PUBLIC_ATPROTO_CLIENT_ID=https://latr.link/client-metadata.json
